{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Notes Merger",
  "version": "0.1.0",
  "identifier": "com.notesmerger.desktop",
  "build": {
    "beforeDevCommand": "npm.cmd run serve",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Notes Merger",
        "width": 1320,
        "height": 860,
        "minWidth": 980,
        "minHeight": 680,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
